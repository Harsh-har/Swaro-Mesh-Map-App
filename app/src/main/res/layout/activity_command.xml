<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ProgressBar
        android:id="@+id/configuration_progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp"
        android:paddingTop="120dp">

        <!-- Light icon -->
        <ImageView
            android:id="@+id/iv_light_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/light"
            android:contentDescription="Light"
            app:tint="#F5A623"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_device_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Lights"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Headline5"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_light_icon"
            app:layout_constraintBottom_toBottomOf="@id/iv_light_icon"
            app:layout_constraintStart_toEndOf="@id/iv_light_icon" />


        <FrameLayout
            android:id="@+id/brightness_row"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:clipChildren="true"
            app:layout_constraintEnd_toStartOf="@id/btn_power"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_light_icon">

            <!-- Fill — width set programmatically on touch/drag -->
            <View
                android:id="@+id/view_brightness_fill"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@color/material_grey_600" />

            <!-- Percentage label, always visible on top -->
            <TextView
                android:id="@+id/tv_slider_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:text="60%"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Headline5"
                android:textSize="18sp"
                android:textStyle="bold" />

        </FrameLayout>

        <!-- Power toggle button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_power"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_settings_power"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            app:iconTint="#AAAAAA"
            app:strokeColor="#333333"
            app:strokeWidth="1.5dp"
            app:cornerRadius="28dp"
            app:backgroundTint="#1E1E1E"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/brightness_row"
            app:layout_constraintBottom_toBottomOf="@id/brightness_row" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>