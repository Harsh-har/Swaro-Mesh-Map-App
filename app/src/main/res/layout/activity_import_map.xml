<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        tools:ignore="MissingConstraints">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize" />

    </com.google.android.material.appbar.AppBarLayout>
    <!-- Back Button -->
    <LinearLayout
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/app_bar">

        <ImageView
            android:id="@+id/imgBackArrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Back"
            android:src="@drawable/back"
            app:tint="@color/backtext" />

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4.2dp"
            android:text="Back"
            android:textColor="@color/backtext"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Step Indicator -->
    <TextView
        android:id="@+id/tvStepIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STEP 3 OF 3 · UPLOAD FILE"
        android:textColor="@color/steptext"
        android:textSize="15sp"
        android:letterSpacing="0.08"
        android:layout_marginStart="20dp"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upload Site File"
        android:textColor="@color/heading_text"
        android:textSize="27.3sp"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        android:layout_marginTop="30dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStepIndicator" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select or drag a file to upload to the site"
        android:textColor="@color/subheading_text"
        android:textSize="15.75sp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- Upload Drop Zone -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDropZone"
        android:layout_width="0dp"
        android:layout_height="256dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="76dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintVertical_bias="0.1"
        app:layout_constraintHeight_min="200dp"
        app:layout_constraintHeight_max="280dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_mapdrop_border">

            <!-- Upload Icon Background -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="60dp"
                android:background="@drawable/bgmap_upload_icon">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_upload"
                    app:tint="#555555"
                    android:contentDescription="Upload icon" />

            </FrameLayout>

            <!-- Tap to select label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to select a file"
                android:textColor="@color/backtext"
                android:textSize="18sp"
                android:layout_marginTop="16.8dp" />

            <!-- Supported formats -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=".json · .csv · .bin · .xml · .cfg · .zip"
                android:textColor="#666666"
                android:textSize="16sp"
                android:layout_marginTop="4.2dp"
                android:layout_marginBottom="59dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Upload to Site Button -->
    <Button
        android:id="@+id/btnUpload"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="41dp"
        android:text="Upload to Site"
        android:textSize="20sp"
        android:textColor="@color/steptext"
        android:enabled="false"
        android:backgroundTint="#1D1D1D"
        android:stateListAnimator="@null"
        style="@style/Widget.MaterialComponents.Button"
        app:cornerRadius="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>